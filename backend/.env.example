# Contextual Inventory Intelligence - backend env
# Copy to .env and fill in real values.

# Groq API (https://console.groq.com/keys). If empty, the backend
# falls back to a rule-based explanation so the API still works.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Path to a trained sklearn-compatible regressor pickled with joblib.
# If the file does not exist we fall back to a heuristic predictor.
# Default points at the repo-root "models/" directory.
MODEL_PATH=../models/model.pkl

# Path to the per-item stats JSON written by scripts/train_model.py.
ITEM_STATS_PATH=../models/item_stats.json

# Historical dataset used by GET /demand-series (the chart baseline).
# The large 75k-row file is the default; the smaller dataset.csv still works.
DATASET_PATH=../dataset/bakery_inventory.csv

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
